{
  "mcpServers": {
    "fabric": {
      "command": "npx",
      "args": ["-y", "@microsoft/fabric-mcp", "server", "start", "--mode", "namespace"],
      "env": {
        "AZURE_TOKEN_CREDENTIALS": "AzureCliCredential"
      }
    },
    "powerbi": {
      "command": "npx",
      "args": ["-y", "powerbi-mcp-server@latest", "--authentication", "azcli", "--tenant", "TODO-tenant-id", "--readonly"],
      "env": {
        "AZURE_TOKEN_CREDENTIALS": "AzureCliCredential"
      }
    },
    "azure-devops": {
      "command": "npx",
      "args": ["-y", "@azure-devops/mcp", "TODO-org-name", "--authentication", "azcli", "-d", "core", "work", "work-items", "search"]
    },
    "microsoft-learn": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://learn.microsoft.com/api/mcp"]
    },
    "context-mode": {
      "command": "npx",
      "args": ["-y", "context-mode@1.0.162"]
    }
  }
}
