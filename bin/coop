#!/usr/bin/env bash
#
# coop — the Cooptimize terminal agent.
#
# A thin, branded layer ON TOP OF Pi (@earendil-works/pi-coding-agent). coop never
# forks Pi: it launches `pi` with Cooptimize skills, prompts, theme, a powerline
# splash/footer extension, and a governance system prompt, and it shells out to
# the standalone Coop tools (coop-data-doc / coop-sql-review / coop-dax-review)
# and the Microsoft Fabric CLI (`fab`).
#
# Usage:
#   coop                      Launch the branded Pi agent (passes extra args to pi)
#   coop doctor               Check dependencies and configuration
#   coop update               Update Pi, Coop tools, vibes, skills/prompts, then doctor
#   coop install              Fresh-install / bootstrap everything (idempotent)
#   coop uninstall            Remove coop from this machine (--keep-tools spares pi + tools)
#   coop sync                 Ensure Pi extensions + place read-only MCP config + verify assets
#   coop data-doc [args]      Run coop-data-doc (default: build) and summarize outputs
#   coop sql-review [args]    Pass through to coop-sql-review (e.g. check <paths>, rules)
#   coop dax-review [args]    Pass through to coop-dax-review (e.g. check <paths>, rules)
#   coop review [paths...]    Run both linters + compose findings onto the lineage docs
#   coop fabric [args]        Pass through to the Microsoft Fabric CLI (`fab`)
#   coop version              Print coop + pi versions
#   coop help                 Show this help
#
# Pi management, aliased under coop (so coop is the only command you type):
#   coop list                 List installed Pi extensions   (-> pi list)
#   coop config               Open Pi's resource TUI         (-> pi config)
#   coop add <source>         Install a Pi extension          (-> pi install <source>)
#   coop install <source>     Same as `coop add` (bare `coop install` bootstraps)
#   coop remove <source>      Remove a Pi extension           (-> pi remove <source>)
#   coop pi <args...>         Raw escape hatch to pi          (-> pi <args...>)
#
set -euo pipefail

# --- Resolve COOP_ROOT and load the shared library ---------------------------
_src="${BASH_SOURCE[0]}"
while [ -h "$_src" ]; do
  _dir="$(cd -P "$(dirname "$_src")" >/dev/null 2>&1 && pwd)"
  _src="$(readlink "$_src")"
  case "$_src" in /*) ;; *) _src="$_dir/$_src" ;; esac
done
COOP_ROOT="$(cd -P "$(dirname "$_src")/.." >/dev/null 2>&1 && pwd)"
export COOP_ROOT
# shellcheck source=lib/common.sh
. "$COOP_ROOT/lib/common.sh"

# Isolate coop's Pi config (extensions, settings, themes, MCP, sessions) from the
# user's personal `pi`. Applies to launching AND the `coop add/remove/list/config/pi`
# management aliases, so they operate on coop's dir — not your global ~/.pi/agent.
# Disable with COOP_NO_ISOLATE=1.
if [ "${COOP_NO_ISOLATE:-0}" != "1" ]; then
  PI_CODING_AGENT_DIR="$(coop_pi_agent_dir)"
  export PI_CODING_AGENT_DIR
  mkdir -p "$PI_CODING_AGENT_DIR" 2>/dev/null || true
fi

usage() {
  cat >&2 <<EOF
${COOP_BOLD}${COOP_NAVY}coop${COOP_RST} ${COOP_DIM}v${COOP_VERSION}${COOP_RST} — the Cooptimize terminal agent (a branded layer on Pi)

${COOP_BOLD}Usage${COOP_RST}
  coop                      Launch the branded Pi agent
  coop doctor               Check dependencies and configuration
  coop update               Update Pi + Coop tools + vibes/skills, then run doctor
  coop install              Fresh-install / bootstrap everything (idempotent)
  coop uninstall            Remove coop from this machine (--keep-tools spares pi + tools)
  coop sync                 Ensure Pi extensions + place read-only MCP config + verify assets
  coop web                  Open a friendly browser UI over the agent (experimental)
  coop data-doc [args]      Run coop-data-doc (default: build) and summarize outputs
  coop sql-review [args]    Pass through to coop-sql-review (e.g. check <paths>, rules)
  coop dax-review [args]    Pass through to coop-dax-review (e.g. check <paths>, rules)
  coop review [paths...]    Run both linters + compose findings onto the lineage docs
                            (--strict: exit 2 on a failing linter; --skip-docs: linters only)
  coop fabric [args]        Pass through to the Microsoft Fabric CLI (fab)
  coop version              Print coop + pi versions
  coop help                 Show this help

${COOP_BOLD}Authoring${COOP_RST}
  coop init [dir]           Scaffold .coop/project.yml into a work repo (default: .)
                            (--seed-docs: generate coop-data-doc.yml from repositories:)
  coop new-skill <name>     Scaffold skills/<name>/SKILL.md
  coop new-prompt <name>    Scaffold prompts/<name>.md
  coop release [level]      Cut a release: bump version + roll CHANGELOG + commit + tag + push
                            (level = patch|minor|major, default patch; --yes, --no-push)

${COOP_BOLD}Pi management (aliased under coop)${COOP_RST}
  coop list                 List installed Pi extensions   (pi list)
  coop config               Open Pi's resource TUI         (pi config)
  coop add <source>         Install a Pi extension         (pi install <source>)
  coop remove <source>      Remove a Pi extension          (pi remove <source>)
  coop pi <args...>         Raw escape hatch to pi

Anything after \`coop\` that is not a known subcommand is passed straight to pi,
e.g. \`coop -c\` resumes the last session, \`coop @notes.md "review this"\`.
EOF
}

# The optional Azure preflight (Power BI token check, cached ~30 min) lives in
# lib/common.sh (coop_az_preflight) — called below by launch_pi and coop_web.

# --- Assemble the exact Pi launch spec (args + brand env) --------------------
# SINGLE SOURCE OF TRUTH for how coop launches Pi. Both `launch_pi` (the terminal
# agent) and `coop launch-spec` (JSON for a future UI / coop web bridge) consume
# this, so the terminal and any other surface can NEVER drift. Populates the global
# COOP_PI_ARGS array and exports the brand env (vibes/splash). PI_CODING_AGENT_DIR
# (isolation) is exported at the top of this script. Read-only; never launches pi.
coop_build_pi_args() {
  COOP_PI_ARGS=()
  # Governance system prompt (read-only-first guardrails). Appended, not replaced.
  [ -f "$COOP_ROOT/docs/guardrails.md" ] && COOP_PI_ARGS+=(--append-system-prompt "$COOP_ROOT/docs/guardrails.md")
  # Cooptimize skills — load each skill folder individually. The official Microsoft
  # drop-in slot (skills/_microsoft/) is SUBORDINATE: a Microsoft skill is surfaced
  # only if it is (a) named in microsoft_skills.allow[] in .coop/project.yml AND
  # (b) does not conflict (by folder name or frontmatter `name:`) with one of our
  # own skills. Cooptimize skills always win.
  if [ -d "$COOP_ROOT/skills" ]; then
    local d name fm allow proj own_names=" "
    for d in "$COOP_ROOT"/skills/*/; do
      [ -d "$d" ] || continue
      name="$(basename "$d")"
      [ "$name" = "_microsoft" ] && continue
      [ -f "${d}SKILL.md" ] || continue
      COOP_PI_ARGS+=(--skill "$d")
      own_names="$own_names$name "
      fm="$(coop_skill_name "${d}SKILL.md")"
      [ -n "$fm" ] && own_names="$own_names$fm "
    done
    proj="$(coop_find_project_yml)"
    if [ -n "$proj" ] && [ -d "$COOP_ROOT/skills/_microsoft" ]; then
      while IFS= read -r allow; do
        [ -z "$allow" ] && continue
        case "$allow" in TODO*) continue ;; esac
        # Validate the name (letters/digits/._-, no `..`, no leading `-`) so a hostile
        # project.yml can't traverse out of skills/_microsoft/ and inject an arbitrary
        # SKILL.md into the model (e.g. allow: "../../../../etc/evil").
        coop_valid_name "$allow" || { coop_warn "ignoring invalid Microsoft skill name '$allow'"; continue; }
        [ -f "$COOP_ROOT/skills/_microsoft/$allow/SKILL.md" ] || continue
        # Skip if the Microsoft skill collides with one of ours (subordinate rule).
        case "$own_names" in *" $allow "*) coop_warn "skipping Microsoft skill '$allow' (conflicts with a Cooptimize skill)"; continue ;; esac
        fm="$(coop_skill_name "$COOP_ROOT/skills/_microsoft/$allow/SKILL.md")"
        if [ -n "$fm" ]; then
          case "$own_names" in *" $fm "*) coop_warn "skipping Microsoft skill '$allow' (name '$fm' conflicts with a Cooptimize skill)"; continue ;; esac
        fi
        COOP_PI_ARGS+=(--skill "$COOP_ROOT/skills/_microsoft/$allow")
      done <<EOF
$(coop_yaml_list "$proj" "microsoft_skills.allow")
EOF
    fi
  fi
  [ -d "$COOP_ROOT/prompts" ]  && COOP_PI_ARGS+=(--prompt-template "$COOP_ROOT/prompts")
  [ -f "$COOP_ROOT/themes/cooptimize.json" ] && COOP_PI_ARGS+=(--theme "$COOP_ROOT/themes/cooptimize.json")
  # Cooptimize companion extensions: branding/splash/vibes, and native review tools.
  [ -e "$COOP_ROOT/extensions/coop-powerline" ]  && COOP_PI_ARGS+=(-e "$COOP_ROOT/extensions/coop-powerline")
  [ -e "$COOP_ROOT/extensions/coop-tools" ]      && COOP_PI_ARGS+=(-e "$COOP_ROOT/extensions/coop-tools")
  [ -e "$COOP_ROOT/extensions/coop-guardrails" ] && COOP_PI_ARGS+=(-e "$COOP_ROOT/extensions/coop-guardrails")
  # Point the extension at our vibe files and brand splash.
  export COOP_VIBES_DIR="$COOP_ROOT/vibes"
  export COOP_SPLASH_FILE="$COOP_ROOT/extensions/coop-powerline/assets/splash.ansi"
}

# --- Launch the branded Pi agent ---------------------------------------------
launch_pi() {
  have pi || coop_die "pi is not installed. Run: coop install   (or: npm install -g @earendil-works/pi-coding-agent)"

  # Guard against launching into a known-broken extension load (agent/extension
  # pi-ai skew). Aborts with instructions when the agent is too old; auto-realigns
  # a merely-stale tree. Fast + read-only. Bypass with COOP_SKIP_EXT_CHECK=1.
  coop_launch_preflight

  # Once-a-day fleet-staleness nudge: warn when this checkout is behind
  # origin/main (throttled fetch, 5s watchdog — never blocks or fails the launch).
  coop_update_nudge

  coop_az_preflight

  coop_build_pi_args
  exec pi ${COOP_PI_ARGS[@]+"${COOP_PI_ARGS[@]}"} "$@"
}

# --- Emit the launch spec (for a UI / coop web bridge) -----------------------
# Internal/advanced. `coop launch-spec` prints the resolved pi invocation
# (human-readable); `--json` emits {"bin","args","env"} for a programmatic consumer
# — e.g. a future coop web bridge that spawns `pi --mode rpc` with the SAME governed
# spec the terminal uses. Read-only: builds the spec, never launches pi.
coop_launch_spec() {
  local want_json=0 a
  for a in "$@"; do [ "$a" = "--json" ] && want_json=1; done
  coop_build_pi_args
  if [ "$want_json" = "1" ]; then
    local py; py="$(coop_python)" || coop_die "python3 is required for: coop launch-spec --json"
    COOP_LS_AGENT_DIR="${PI_CODING_AGENT_DIR:-}" \
    COOP_LS_VIBES="${COOP_VIBES_DIR:-}" \
    COOP_LS_SPLASH="${COOP_SPLASH_FILE:-}" \
    "$py" - ${COOP_PI_ARGS[@]+"${COOP_PI_ARGS[@]}"} <<'PY'
import json, os, sys
env = {}
for out_key, src_key in (("PI_CODING_AGENT_DIR", "COOP_LS_AGENT_DIR"),
                         ("COOP_VIBES_DIR", "COOP_LS_VIBES"),
                         ("COOP_SPLASH_FILE", "COOP_LS_SPLASH")):
    val = os.environ.get(src_key, "")
    if val:
        env[out_key] = val
print(json.dumps({"bin": "pi", "args": sys.argv[1:], "env": env}, indent=2))
PY
  else
    printf 'pi'
    local x
    for x in ${COOP_PI_ARGS[@]+"${COOP_PI_ARGS[@]}"}; do printf ' %q' "$x"; done
    printf '\n'
  fi
}

# --- coop web (experimental): friendly browser UI over `pi --mode rpc` --------
# Spawns the SAME governed coop the terminal runs, but drives it from a local
# browser window (SSE bridge). Uses the shared launch spec so it can never drift
# from the terminal. Localhost + one-time token; see web/server.mjs and
# docs/coop-web-plan.md.
coop_web() {
  have pi   || coop_die "pi is not installed. Run: coop install"
  have node || coop_die "Node.js is required for coop web. Run: coop install"
  coop_launch_preflight
  coop_az_preflight   # same Fabric/Power BI token check the terminal launch does
  local spec
  spec="$(coop_launch_spec --json)" || coop_die "couldn't build the launch spec for coop web"
  COOP_LAUNCH_SPEC="$spec" exec node "$COOP_ROOT/web/server.mjs" "$@"
}

# --- Tool passthrough --------------------------------------------------------
# Flow straight through to a standalone Coop tool: every subcommand (check, rules,
# upgrade, …) and the tool's own interactive prompts (e.g. coop-sql-review's
# subfolder picker) work, and the exit code propagates. The AI agent gets structured
# JSON via the native sql_review / dax_review tools in extensions/coop-tools.
run_tool() {
  local bin="$1"; shift
  have "$bin" || coop_die "$bin is not installed. Run: coop install"
  coop_head "$bin ${*:-}"
  exec "$bin" "$@"
}

run_data_doc() {
  have coop-data-doc || coop_die "coop-data-doc is not installed. Run: coop install"
  if [ "$#" -eq 0 ]; then set -- build; fi
  # Pass straight through to coop-data-doc — including its interactive `setup` wizard
  # and `init`. The tool handles its own first-run setup (it tells you to run
  # `init`/`setup` when coop-data-doc.yml is missing); coop never auto-creates it.
  coop_head "coop-data-doc $*"
  # Capture the exit code instead of letting `set -e` abort here, so the artifact
  # summary below still prints on a non-zero exit (e.g. `check` flagging stale docs)
  # — matching Invoke-DataDoc in bin/coop.ps1. The code propagates via `return $rc`.
  local rc=0
  coop-data-doc "$@" || rc=$?
  # Summarize machine-readable artifacts when present (manifest.json / graph.json).
  # Includes the default output dir (./data-docs) plus legacy/alternate locations.
  local f
  for f in data-docs/manifest.json data-docs/graph.json manifest.json graph.json docs/manifest.json docs/graph.json site/manifest.json data-docs-site/manifest.json; do
    if [ -f "$f" ]; then
      coop_ok "Machine-readable output: $f"
      local py; py="$(coop_python)" || break
      "$py" - "$f" <<'PY' 2>/dev/null || true
import sys, json
try:
    d = json.load(open(sys.argv[1]))
except Exception:
    sys.exit(0)
def n(*keys):
    for k in keys:
        v = d.get(k)
        if isinstance(v, list): return len(v)
        if isinstance(v, dict): return len(v)
    return None
parts=[]
for label,keys in [("nodes",("nodes","objects","entities")),("edges",("edges","links","lineage")),("docs",("documents","docs","pages"))]:
    c=n(*keys)
    if c is not None: parts.append(f"{c} {label}")
if parts: print("  " + ", ".join(parts))
PY
      break
    fi
  done
  return "$rc"   # mirror Invoke-DataDoc: a coop-data-doc failure must not be masked by the summary
}

# --- coop review: both linters + compose findings onto the lineage docs -------
# One command for the whole advisory loop: run coop-sql-review AND coop-dax-review
# over the same scope (each tool filters by file type itself), save both JSON
# reports under .coop/reviews/ next to the contract, then rebuild the lineage docs
# with the findings composed in (coop-data-doc build --reviews …). Scope: explicit
# paths win; with none, the nearest .coop/project.yml's repositories.*.local_path
# entries — the same contract scoping the native sql_review/dax_review tools use
# (TODO placeholders and paths missing on this machine are skipped with a note).
# NEVER blind-scans the cwd. Advisory: linter findings don't fail the run unless
# --strict; docs-not-set-up is a hint, not a failure; a hard data-doc failure
# (exit 2) propagates.
run_review() {
  local strict=0 skip_docs=0 compare=0 do_html=0 diff_mode=0 diff_ref=""
  local scope=()
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --diff)      diff_mode=1; if [ "$#" -gt 1 ] && case "$2" in -*) false ;; *) true ;; esac; then diff_ref="$2"; shift; else diff_ref="HEAD"; fi ;;
      --diff=*)    diff_mode=1; diff_ref="${1#*=}" ;;
      --strict)    strict=1 ;;
      --skip-docs) skip_docs=1 ;;
      --compare)   compare=1 ;;
      --html)      do_html=1 ;;
      -h|--help)
        cat >&2 <<'EOF'
Usage: coop review [paths...] [--strict] [--skip-docs] [--compare] [--html]
  Run coop-sql-review AND coop-dax-review over the project scope (explicit paths
  win; else the nearest .coop/project.yml's repositories.*.local_path entries),
  save both JSON reports under .coop/reviews/, then rebuild the lineage docs with
  the findings composed in (coop-data-doc build --reviews …).
  --strict      pass --strict to both linters; exit 2 if either exits non-zero
  --skip-docs   skip the coop-data-doc build step (linters only)
  --compare     diff each linter against the previous run's saved report and print
                a new/fixed/persisting delta (first run just becomes the baseline)
  --html        write a combined HTML suite report to .coop/reviews/suite.html
  --diff [ref]  review only the files changed since [ref] (default: HEAD)
                in git-tracked roots, falling back to full review for others
EOF
        return 0 ;;
      -*) coop_die "unknown flag '$1' — usage: coop review [paths...] [--strict] [--skip-docs] [--compare] [--diff [ref]] [--html]" ;;
      *)  scope+=("$1") ;;
    esac
    shift
  done

  have coop-sql-review || coop_die "coop-sql-review is not installed. Run: coop install"
  have coop-dax-review || coop_die "coop-dax-review is not installed. Run: coop install"
  if [ "$skip_docs" != 1 ]; then
    have coop-data-doc || coop_die "coop-data-doc is not installed. Run: coop install   (or skip the docs step: coop review --skip-docs)"
  fi

  # Scope + output dir from the project contract (same semantics as coop-tools'
  # contractReviewScope: resolve against the contract's repo root, existing only).
  local proj outdir base p abs
  proj="$(coop_find_project_yml)"
  if [ -n "$proj" ]; then outdir="$(dirname "$proj")/reviews"; else outdir=".coop/reviews"; fi
  if [ "${#scope[@]}" -eq 0 ] && [ -n "$proj" ]; then
    base="$(dirname "$(dirname "$proj")")"
    while IFS= read -r p; do
      [ -z "$p" ] && continue
      case "$p" in TODO*) coop_warn "skipping a repositories.local_path that is still a TODO placeholder"; continue ;; esac
      case "$p" in /*) abs="$p" ;; *) abs="$base/$p" ;; esac
      if [ -e "$abs" ]; then scope+=("$abs"); else coop_warn "skipping ${p} (not found on this machine)"; fi
    done <<EOF
$(coop_yaml_list "$proj" "repositories.*.local_path")
EOF
  fi
  [ "${#scope[@]}" -gt 0 ] || coop_die "nothing to review — run inside a project with .coop/project.yml (repositories.*.local_path filled), or pass paths: coop review <paths...>"

  mkdir -p "$outdir" || coop_die "cannot create $outdir"

  if [ "${diff_mode:-0}" = 1 ]; then
    local new_scope=()
    local item file
    for item in "${scope[@]}"; do
      if [ -d "$item" ]; then
        if git -C "$item" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
          while IFS= read -r -d '' file; do
            if [ -e "$item/$file" ]; then new_scope+=("$item/$file"); fi
          done < <(git -C "$item" diff --name-only -z "$diff_ref" --; git -C "$item" ls-files -z --others --exclude-standard)
        else
          coop_warn "$item is not a git repository; falling back to full review for this root"
          new_scope+=("$item")
        fi
      elif [ -f "$item" ]; then
        new_scope+=("$item")
      fi
    done
    scope=("${new_scope[@]}")
    if [ "${#scope[@]}" -eq 0 ]; then
      coop_info "coop review --diff: no files changed in the scope."
      return 0
    fi
  fi
  local sql_json="$outdir/coop-sql-review.json" dax_json="$outdir/coop-dax-review.json" bpa_json="$outdir/bpa-review.json"
  local sql_rc=0 dax_rc=0 bpa_rc=0 dd_rc=0
  local extra=()
  [ "$strict" = 1 ] && extra=(--strict)

  # --compare: snapshot each linter's previous saved report to a temp file, then hand it
  # to the linter as --diff-against so it prints a new/fixed/persisting delta (the run
  # overwrites the saved copy via -o, so we compare against the snapshot). A first run
  # has nothing to diff — it just becomes the baseline for the next --compare.
  local sql_prev="" dax_prev=""
  local sql_diff=() dax_diff=()
  if [ "$compare" = 1 ]; then
    if [ -f "$sql_json" ]; then sql_prev="$(mktemp)"; cp "$sql_json" "$sql_prev"; sql_diff=(--diff-against "$sql_prev"); fi
    if [ -f "$dax_json" ]; then dax_prev="$(mktemp)"; cp "$dax_json" "$dax_prev"; dax_diff=(--diff-against "$dax_prev"); fi
    { [ -n "$sql_prev" ] || [ -n "$dax_prev" ]; } || coop_info "no previous review to compare against yet — this run becomes the baseline"
  fi

  # Run both linters over the SAME scope; capture exit codes, never abort here.
  coop_head "coop-sql-review check → $sql_json"
  coop-sql-review check ${scope[@]+"${scope[@]}"} --format json -o "$sql_json" ${sql_diff[@]+"${sql_diff[@]}"} ${extra[@]+"${extra[@]}"} || sql_rc=$?
  [ "$sql_rc" -eq 0 ] || coop_warn "coop-sql-review exited $sql_rc"
  coop_head "coop-dax-review check → $dax_json"
  coop-dax-review check ${scope[@]+"${scope[@]}"} --format json -o "$dax_json" ${dax_diff[@]+"${dax_diff[@]}"} ${extra[@]+"${extra[@]}"} || dax_rc=$?
  [ "$dax_rc" -eq 0 ] || coop_warn "coop-dax-review exited $dax_rc"
  
  # Tabular Editor BPA check (if enabled in project.yml)
  local bpa_prev=""
  if [ -n "$proj" ]; then
    local py_cmd
    if py_cmd="$(coop_python)"; then
      if [ "$compare" = 1 ] && [ -f "$bpa_json" ]; then bpa_prev="$(mktemp)"; cp "$bpa_json" "$bpa_prev"; fi
      "$py_cmd" "$COOP_ROOT/lib/_bpa_runner.py" "$proj" "$bpa_json" ${scope[@]+"${scope[@]}"} || bpa_rc=$?
      if [ -f "$bpa_json" ]; then
        coop_head "Tabular Editor BPA → $bpa_json"
        [ "$bpa_rc" -eq 0 ] || coop_warn "Tabular Editor BPA exited $bpa_rc"
      fi
      [ -n "$bpa_prev" ] && rm -f "$bpa_prev"
    fi
  fi

  [ -n "$sql_prev" ] && rm -f "$sql_prev"
  [ -n "$dax_prev" ] && rm -f "$dax_prev"

  # Compose the findings onto the lineage docs (unless --skip-docs).
  if [ "$skip_docs" = 1 ]; then
    coop_info "skipping the lineage-docs step (--skip-docs)"
  else
    coop_head "coop-data-doc build (composing review findings)"
    local dd_args=(build --non-interactive --reviews "$sql_json" --reviews "$dax_json")
    [ -f "$bpa_json" ] && dd_args+=(--reviews "$bpa_json")
    coop-data-doc "${dd_args[@]}" || dd_rc=$?
    if [ "$dd_rc" -eq 1 ]; then
      # Friendly "no config" exit — the findings are still saved; docs are an aid, not a gate.
      coop_warn "lineage docs not set up — findings saved, docs step skipped" "set up lineage docs first: coop data-doc setup   (or /setup-docs in the agent)"
      dd_rc=0
    elif [ "$dd_rc" -ne 0 ]; then
      coop_err "coop-data-doc build failed (exit $dd_rc)"
    else
      local d
      for d in data-docs-site site; do
        [ -f "$d/index.html" ] && { coop_ok "Portal: $d/index.html"; break; }
      done
    fi
  fi

  # Summary: use coop_review_core.suite to aggregate.
  local py_cmd
  if py_cmd="$(coop_python)"; then
    "$py_cmd" - "$sql_json" "$dax_json" "$bpa_json" "$do_html" "$outdir/suite.html" <<'PY' || true
import sys, os
from coop_review_core.suite import load_envelopes, suite_summary, suite_text, suite_html

paths = [p for p in sys.argv[1:4] if os.path.exists(p)]
if not paths:
    sys.exit(0)

try:
    envs = load_envelopes(paths)
    summary = suite_summary(envs)
    print("\n" + suite_text(envs, summary, color=True))
    
    do_html = sys.argv[4] == "1"
    if do_html:
        html_out = sys.argv[5]
        html_paths = {}
        for env in envs:
            t = env.get("tool")
            if t:
                # We link to the specific tool's HTML if it exists in the same dir.
                # Assuming the linters wrote foo.json and maybe foo.html.
                html_file = os.path.join(os.path.dirname(html_out), f"{t}.html")
                if os.path.exists(html_file):
                    html_paths[t] = f"{t}.html"
        
        with open(html_out, "w", encoding="utf-8") as f:
            f.write(suite_html(envs, summary, html_paths))
        print(f"Suite HTML Report: {html_out}\n")
except Exception as exc:
    print(f"Suite summary error: {exc}", file=sys.stderr)
PY
  else
    coop_ok "Reports: $sql_json $dax_json $bpa_json"
  fi
  coop_info "Tip: add these files to coop-data-doc.yml's reviews: list so CI check sees the same inputs."

  # Exit: hard data-doc failures propagate; --strict makes a failing linter exit 2.
  [ "$dd_rc" -ge 2 ] && exit "$dd_rc"
  if [ "$strict" = 1 ]; then
    if [ "$sql_rc" -ne 0 ] || [ "$dax_rc" -ne 0 ] || [ "$bpa_rc" -ne 0 ]; then exit 2; fi
  fi
  return 0
}

# --- Authoring scaffolders ---------------------------------------------------
# Validate a kebab-case-ish resource name (letters, digits, _ . -).
coop_valid_name() { case "$1" in ""|.|..|-*|*[!a-zA-Z0-9._-]*) return 1 ;; *) return 0 ;; esac; }

coop_init() {
  # coop init [dir]              scaffold .coop/project.yml (current behavior)
  # coop init --seed-docs [dir]  generate/patch coop-data-doc.yml from an EXISTING
  #                              contract's repositories: (paths typed once, not twice)
  # coop init --ci github|ado    generate CI pipeline
  local seed=0 dir="" a ci_type=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --seed-docs) seed=1 ;;
      --ci) shift; ci_type="$1" ;;
      --yes|-y) export COOP_ASSUME_YES=1 ;;
      -*) coop_die "unknown flag '$1' — usage: coop init [dir] [--seed-docs] [--ci github|ado] [--yes]" ;;
      *) dir="$1" ;;
    esac
    shift
  done
  [ -n "$dir" ] || dir="$PWD"
  if [ "$seed" = 1 ]; then
    coop_init_seed_docs "$dir"
    return $?
  fi
  if [ -n "$ci_type" ]; then
    coop_init_ci "$dir" "$ci_type"
    return $?
  fi
  local dst="$dir/.coop/project.yml"
  [ -f "$COOP_ROOT/.coop/project.example.yml" ] || coop_die "template missing: .coop/project.example.yml"
  [ -e "$dst" ] && coop_die "$dst already exists — not overwriting.  (seed coop-data-doc.yml from it with: coop init --seed-docs)"
  mkdir -p "$dir/.coop"
  cp "$COOP_ROOT/.coop/project.example.yml" "$dst"
  coop_ok "Wrote $dst"
  coop_info "Fill in the TODOs (repo paths, Fabric/Power BI workspaces, tenant), then: coop doctor"
  coop_info "Once repositories: is filled, seed the lineage-docs config from it: coop init --seed-docs"
  coop_info "Or set up lineage docs interactively: \`coop data-doc setup\` (full wizard) — or launch \`coop\` and accept the /setup-docs offer."
}

# Seed coop-data-doc.yml's repos: from the contract's repositories: (issue #25) —
# the same paths typed once. lib/_seeddocs.py classifies the filled repos into
# coop-data-doc's sql/powerbi slots (TODO placeholders skipped with a note) and
# prints the JSON patch; `coop-data-doc config-set --from-json -` applies it
# non-destructively (only the keys in the patch change). Declining changes nothing.
coop_init_seed_docs() {
  local dir="$1" proj="$1/.coop/project.yml" py patch rc=0
  [ -f "$proj" ] || coop_die "no $proj — run 'coop init' first, then fill repositories:."
  py="$(coop_python)" || coop_die "python3 is required for: coop init --seed-docs"
  have coop-data-doc || coop_die "coop-data-doc is not installed. Run: coop install"
  # The mapping summary (and any skip notes) print to stderr; the patch is stdout.
  patch="$("$py" "$COOP_ROOT/lib/_seeddocs.py" "$proj")" || rc=$?
  if [ "$rc" = 3 ]; then
    coop_warn "nothing to seed yet" "fill repositories.*.local_path in $proj (TODO placeholders are skipped), then re-run: coop init --seed-docs"
    return 1
  fi
  { [ "$rc" = 0 ] && [ -n "$patch" ]; } || coop_die "could not read repositories from $proj"
  if ! coop_confirm "Write these repos into $dir/coop-data-doc.yml?"; then
    coop_info "seed cancelled — nothing changed."
    return 1
  fi
  if printf '%s' "$patch" | coop-data-doc config-set --config "$dir/coop-data-doc.yml" --from-json - >/dev/null; then
    coop_ok "seeded $dir/coop-data-doc.yml from project.yml (repos)"
    coop_info "review it, then build the lineage docs: coop data-doc   (or /setup-docs inside the agent)"
  else
    coop_die "coop-data-doc config-set failed — apply the patch by hand: $py $COOP_ROOT/lib/_seeddocs.py $proj | coop-data-doc config-set --from-json -"
  fi
}

coop_new_skill() {
  local name="${1:-}"
  coop_valid_name "$name" || coop_die "Usage: coop new-skill <name>  (letters, digits, . _ - only)"
  local dir="$COOP_ROOT/skills/$name"
  [ "$name" = "_microsoft" ] && coop_die "'_microsoft' is reserved for official Microsoft skills."
  [ -e "$dir" ] && coop_die "skills/$name already exists."
  mkdir -p "$dir"
  cat > "$dir/SKILL.md" <<EOF
---
name: $name
description: TODO one-line summary of when to use this skill.
---

# ${name} skill

TODO: when to use this skill.

## Checklist
- TODO
- TODO

## Tools
- Use the native tools (sql_review / dax_review / data_doc) and read-only MCP as needed.
- Operates under the coop-workflow skill and docs/guardrails.md (advisory, read-only first).

## Output
- Pass/fail summary, findings by severity, suggested fixes (advisory — never auto-edit).
EOF
  coop_ok "Created skills/$name/SKILL.md"
  coop_info "Edit it, test with: coop  — then commit & push so the team gets it."
}

coop_new_prompt() {
  local name="${1:-}"
  coop_valid_name "$name" || coop_die "Usage: coop new-prompt <name>  (letters, digits, . _ - only)"
  local f="$COOP_ROOT/prompts/$name.md"
  [ -e "$f" ] && coop_die "prompts/$name.md already exists."
  cat > "$f" <<EOF
# ${name}

Use the \`coop-workflow\` skill.

Task: TODO describe the task for {{subject}}.
Goal: {{goal}}

Steps:
1. Read .coop/project.yml and the relevant standards.
2. TODO …
3. Keep read-only first; present a PLAN and get approval before any edit.
4. Never commit source — show the diff and let a human commit.
EOF
  coop_ok "Created prompts/$name.md"
  coop_info "Edit it, then it loads automatically next time you run: coop"
}

# --- Release gate: tested_with pins vs coop-website/versions.json -------------
# config/defaults.yml pins the coop-tool versions coop was last verified against
# (tested_with.coop_data_doc/_sql_review/_dax_review — the "tested" column of
# `coop update --check`); the sibling coop-website checkout's versions.json is the
# suite's single source of truth for released version strings. Verify the three
# pins BEFORE tagging so they can't drift releases-stale again (issue #23):
#   - pins match versions.json      -> ok, continue
#   - a pin disagrees / unreadable  -> die (fix defaults.yml, or --no-check)
#   - sibling checkout missing      -> warn + confirm (offline / partial clones
#                                      stay workable; --yes continues with a note)
# Returns 1 when the user declines the confirm (caller cancels the release).
coop_release_check_pins() {
  local assume_yes="${1:-0}"
  local defaults="$COOP_ROOT/config/defaults.yml"
  local vjson="$COOP_ROOT/../coop-website/versions.json"
  if [ ! -f "$vjson" ]; then
    coop_warn "sibling coop-website checkout not found — can't verify config/defaults.yml tested_with against versions.json (see RELEASE.md)."
    if [ "$assume_yes" = "1" ]; then
      coop_info "continuing (--yes) — verify the tested_with pins by hand."
      return 0
    fi
    coop_confirm "Release without verifying the tested_with pins?" || return 1
    return 0
  fi
  local tool key pin rel mismatch=0
  for tool in coop-data-doc coop-sql-review coop-dax-review; do
    key="$(printf '%s' "$tool" | tr '-' '_')"
    pin="$(coop_yaml_get "$defaults" "tested_with.$key" "")"
    # versions.json keeps a strict one-`"key": "value"`-per-line layout (enforced
    # by coop-website's own checker), so sed is safe — and python-free — here.
    rel="$(sed -n 's/^[[:space:]]*"'"$tool"'"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$vjson" | head -1)"
    if [ -z "$rel" ]; then
      coop_warn "could not read $tool from coop-website/versions.json — skipping its pin check."
      continue
    fi
    if [ -z "$pin" ]; then
      coop_warn "could not read tested_with.$key from config/defaults.yml (versions.json says $tool is $rel)."
      mismatch=1
    elif [ "$pin" != "$rel" ]; then
      coop_warn "tested_with.$key is $pin but coop-website/versions.json says $tool is $rel."
      mismatch=1
    fi
  done
  if [ "$mismatch" = "1" ]; then
    coop_die "tested_with pins disagree with coop-website/versions.json — update config/defaults.yml (see RELEASE.md), or re-run with --no-check."
  fi
  coop_ok "tested_with pins match coop-website/versions.json"
}

# --- Release: bump version, roll CHANGELOG, commit + tag (+ push) -------------
# Cut a release with one command. Bumps VERSION + every extensions/*/package.json,
# rolls the CHANGELOG's [Unreleased] section into a dated [X.Y.Z] heading, commits,
# tags vX.Y.Z, and pushes the commit + tag. Requires a clean working tree.
coop_release() {
  local level="" assume_yes=0 do_push=1 do_check=1
  while [ "$#" -gt 0 ]; do
    case "$1" in
      patch|minor|major) level="$1" ;;
      -y|--yes)          assume_yes=1 ;;
      --no-push)         do_push=0 ;;
      --check)           do_check=1 ;;
      --no-check)        do_check=0 ;;
      -h|--help)
        cat >&2 <<'EOF'
Usage: coop release [patch|minor|major] [--yes] [--no-push] [--no-check]
  Bump VERSION + extension manifests, roll CHANGELOG [Unreleased] into a dated
  release, commit, tag vX.Y.Z, and push (commit + tag). Default level: patch.
  Verifies extensions transpile + tests + bash/PowerShell parity pass, and that
  the tested_with coop-tool pins match the sibling coop-website's versions.json
  (--no-check to skip).
  Requires a clean working tree (commit your changes first).
EOF
        return 0 ;;
      *) coop_die "unknown arg '$1' — usage: coop release [patch|minor|major] [--yes] [--no-push] [--no-check]" ;;
    esac
    shift
  done
  [ -n "$level" ] || level="patch"

  have git || coop_die "git is required for 'coop release'."
  git -C "$COOP_ROOT" rev-parse --is-inside-work-tree >/dev/null 2>&1 \
    || coop_die "$COOP_ROOT is not a git checkout."
  [ -z "$(git -C "$COOP_ROOT" status --porcelain)" ] \
    || coop_die "working tree not clean — commit or stash your changes before releasing."

  local cur new ma mi pa
  # Guard the read first: a missing/unreadable VERSION makes the `<` redirect fail
  # BEFORE `2>/dev/null` applies, so under `set -e` bash would abort with a raw error
  # instead of reaching the friendly validation below.
  [ -f "$COOP_ROOT/VERSION" ] || coop_die "VERSION file missing at $COOP_ROOT/VERSION — fix it before releasing."
  cur="$(tr -d '[:space:]' < "$COOP_ROOT/VERSION" 2>/dev/null || true)"
  # Strict X.Y.Z. The old loose globs let e.g. '1abc.2.3' or '1.2.3.4' through, then
  # `$((ma + 1))` aborted mid-release with a raw arithmetic error under `set -e`.
  case "$cur" in
    ''|*[!0-9.]*|.*|*.|*..*|*.*.*.*) coop_die "VERSION ('$cur') is not X.Y.Z — fix it before releasing." ;;
  esac
  IFS=. read -r ma mi pa <<<"$cur"
  for _f in "$ma" "$mi" "$pa"; do
    case "$_f" in ''|*[!0-9]*) coop_die "VERSION ('$cur') is not X.Y.Z — fix it before releasing." ;; esac
  done
  case "$level" in
    major) new="$((ma + 1)).0.0" ;;
    minor) new="${ma}.$((mi + 1)).0" ;;
    patch) new="${ma}.${mi}.$((pa + 1))" ;;
  esac

  if git -C "$COOP_ROOT" rev-parse "v$new" >/dev/null 2>&1; then coop_die "tag v$new already exists."; fi

  # Pre-flight: never tag code that doesn't transpile. Skips silently when npx is
  # unavailable; bypass with --no-check.
  if [ "$do_check" = "1" ]; then
    # Track whether the transpile/test gate actually ran. A host missing npx/node
    # skips those halves; if a push is requested we fail closed below rather than
    # publish an unverified tag — mirroring bin/coop.ps1's Invoke-CoopRelease.
    local gate_skipped=0
    if have npx; then
      local extf build_fail=0
      for extf in "$COOP_ROOT"/extensions/*/index.ts; do
        [ -f "$extf" ] || continue
        if ! npx -y esbuild "$extf" --bundle --format=esm --platform=node --packages=external --outfile=/dev/null >/dev/null 2>&1; then
          coop_warn "extension does not build: ${extf#"$COOP_ROOT"/}"; build_fail=1
        fi
      done
      [ "$build_fail" = "1" ] && coop_die "extension build check failed — fix it, or re-run with --no-check."
      coop_ok "extensions build"
    else
      coop_warn "npx not found — skipping the extension build check."; gate_skipped=1
    fi

    # A release tags exactly the (clean) working tree, so gate on the full Node
    # suite and the bash/PowerShell parity check — the transpile above only proves
    # the extensions compile, not that the tests or the .ps1 pairing pass. These
    # run on the already-clean tree, so they test precisely what will ship.
    if [ -f "$COOP_ROOT/tests/run.sh" ]; then
      if have node; then
        local test_log; test_log="$(mktemp)" || coop_die "mktemp failed."
        if bash "$COOP_ROOT/tests/run.sh" >"$test_log" 2>&1; then
          coop_ok "tests pass"; rm -f "$test_log"
        else
          cat "$test_log" >&2; rm -f "$test_log"
          coop_die "tests failed (bash tests/run.sh) — fix them, or re-run with --no-check."
        fi
      else
        coop_warn "node not found — skipping the test suite."; gate_skipped=1
      fi
    fi
    if [ -f "$COOP_ROOT/scripts/check-parity.sh" ]; then
      if bash "$COOP_ROOT/scripts/check-parity.sh" >/dev/null 2>&1; then
        coop_ok "parity check passes"
      else
        coop_die "parity check failed (bash scripts/check-parity.sh) — fix it, or re-run with --no-check."
      fi
    fi

    # Fail closed: a host that could not run the transpile/test gate must not
    # PUBLISH an unverified tag. Bumping/committing locally (--no-push) is fine; a
    # push requires the gate to have run — or an explicit --no-check opt-out (which
    # skips this whole block). Matches bin/coop.ps1's Invoke-CoopRelease.
    if [ "$gate_skipped" = "1" ] && [ "$do_push" = "1" ]; then
      coop_die "release gate could not run (npx/node not found) — install Node.js, use --no-push to bump locally only, or --no-check to release without gating."
    fi

    # tested_with pins vs the sibling coop-website's versions.json: a mismatch
    # dies; a missing sibling warns + confirms (--yes continues). See the
    # function header above and RELEASE.md.
    coop_release_check_pins "$assume_yes" \
      || { coop_info "release cancelled — nothing changed."; return 1; }
  fi

  local pushmsg=""; [ "$do_push" = "1" ] && pushmsg=" + push"
  if [ "$assume_yes" != "1" ]; then
    coop_confirm "Release v${cur} → v${new}? (bump VERSION + manifests, roll CHANGELOG, commit, tag v${new}${pushmsg})" \
      || { coop_info "release cancelled — nothing changed."; return 1; }
  fi

  local today tmp f
  today="$(date +%F)"

  # 1. VERSION
  printf '%s\n' "$new" > "$COOP_ROOT/VERSION"

  # 2. extension manifests (sed without -i for mac/linux portability)
  for f in "$COOP_ROOT"/extensions/*/package.json; do
    [ -f "$f" ] || continue
    tmp="$(mktemp)" || coop_die "mktemp failed."
    sed 's/"version": *"[0-9][^"]*"/"version": "'"$new"'"/' "$f" > "$tmp" && mv "$tmp" "$f"
  done

  # 3. CHANGELOG: insert a dated [X.Y.Z] heading right under [Unreleased]
  if grep -q '^## \[Unreleased\]' "$COOP_ROOT/CHANGELOG.md" 2>/dev/null; then
    tmp="$(mktemp)" || coop_die "mktemp failed."
    awk -v ver="$new" -v d="$today" '
      !done && /^## \[Unreleased\]/ { print; print ""; print "## [" ver "] — " d; done=1; next }
      { print }
    ' "$COOP_ROOT/CHANGELOG.md" > "$tmp" && mv "$tmp" "$COOP_ROOT/CHANGELOG.md"
  else
    coop_warn "no '## [Unreleased]' heading in CHANGELOG.md — skipped the changelog roll."
  fi

  # 4. commit + tag. Stage ONLY the files a release actually touches — never `add -A`,
  # which would sweep in anything created during the (slow) gate window if another
  # agent or an editor autosave shares the tree (this is how a spurious empty release
  # got cut once). VERSION + CHANGELOG are repo-relative to git's -C dir.
  git -C "$COOP_ROOT" add VERSION CHANGELOG.md
  for f in "$COOP_ROOT"/extensions/*/package.json; do
    [ -f "$f" ] && git -C "$COOP_ROOT" add "$f"
  done
  git -C "$COOP_ROOT" commit -q -m "Release v$new" || coop_die "git commit failed."
  git -C "$COOP_ROOT" tag -a "v$new" -m "coop-agent v$new" || coop_die "git tag failed."
  coop_ok "released v$new (was v$cur)"

  # 5. push
  if [ "$do_push" = "1" ]; then
    local branch; branch="$(git -C "$COOP_ROOT" rev-parse --abbrev-ref HEAD)"
    git -C "$COOP_ROOT" push origin "$branch" >/dev/null 2>&1 && coop_ok "pushed $branch" \
      || coop_warn "git push $branch failed — push manually: git push origin $branch"
    git -C "$COOP_ROOT" push origin "v$new" >/dev/null 2>&1 && coop_ok "pushed tag v$new" \
      || coop_warn "git push tag failed — push manually: git push origin v$new"
  else
    coop_info "not pushed (--no-push). When ready: git push origin HEAD && git push origin v$new"
  fi
}

# Surface freshly-installed tools (npm-global `pi`, pipx `fab`/coop-*) on PATH for
# this process so a shell whose persistent PATH predates the install still finds
# them. Best-effort; only prepends dirs that exist.
_coop_add_runtime_paths() {
  local d p
  if have npm; then
    # `|| true`: a failing `npm prefix -g` (broken node, corrupt .npmrc, EACCES) must
    # not abort coop under `set -euo pipefail` — that would brick even `coop help`.
    p="$(npm prefix -g 2>/dev/null || true)"
    if [ -n "$p" ] && [ -d "$p/bin" ]; then
      case ":$PATH:" in *":$p/bin:"*) ;; *) PATH="$p/bin:$PATH" ;; esac
    fi
  fi
  d="$HOME/.local/bin"
  if [ -d "$d" ]; then
    case ":$PATH:" in *":$d:"*) ;; *) PATH="$d:$PATH" ;; esac
  fi
  export PATH
  hash -r 2>/dev/null || true
}
_coop_add_runtime_paths

# --- Dispatch ----------------------------------------------------------------
cmd="${1:-}"
case "$cmd" in
  "")            launch_pi ;;
  # Dry-run: run the launch preflights but PRINT the resolved pi invocation instead of
  # exec'ing it — the flag name's plain meaning (it used to launch, the opposite). Same
  # stdout as `coop launch-spec`; trailing args (e.g. --json) pass through. Preflight is
  # a no-op when pi is absent, so this exits 0 even on a machine without pi installed.
  --no-launch)   shift; coop_launch_preflight; coop_launch_spec "$@" ;;
  doctor)        shift; exec "$COOP_ROOT/scripts/doctor.sh" "$@" ;;
  update)        shift; exec "$COOP_ROOT/scripts/update.sh" "$@" ;;
  bootstrap)     shift; exec "$COOP_ROOT/scripts/install.sh" "$@" ;;
  install)
    # Bare `coop install` (or with bootstrap flags) bootstraps the whole stack.
    # `coop install <source>` adds a Pi extension (alias of `coop add`).
    shift
    if [ "$#" -eq 0 ] || [ "${1#-}" != "$1" ]; then
      exec "$COOP_ROOT/scripts/install.sh" "$@"
    fi
    have pi || coop_die "pi not installed. Run: coop bootstrap"
    exec pi install "$@"
    ;;
  sync)          shift; exec "$COOP_ROOT/scripts/sync.sh" "$@" ;;
  web)           shift; coop_web "$@" ;;
  launch-spec)   shift; coop_launch_spec "$@" ;;
  init)          shift; coop_init "$@" ;;
  new-skill)     shift; coop_new_skill "$@" ;;
  new-prompt)    shift; coop_new_prompt "$@" ;;
  release)       shift; coop_release "$@" ;;
  data-doc)      shift; run_data_doc "$@" ;;
  sql-review)    shift; run_tool coop-sql-review "$@" ;;
  dax-review)    shift; run_tool coop-dax-review "$@" ;;
  review)        shift; run_review "$@" ;;
  fabric|fab)    shift; have fab || coop_die "Microsoft Fabric CLI (fab) not found. Run: coop install"; exec fab "$@" ;;
  # --- Pi management, aliased under coop ---
  add)           shift; have pi || coop_die "pi not installed. Run: coop bootstrap"; exec pi install "$@" ;;
  remove)        shift; have pi || coop_die "pi not installed."; exec pi remove "$@" ;;
  uninstall)
    # Bare `coop uninstall` (or with flags) removes coop's footprint from this
    # machine (scripts/uninstall.sh; --keep-tools spares pi + the pipx tools).
    # `coop uninstall <source>` removes a Pi extension (alias of `coop remove`) —
    # the same bare-vs-source split `coop install` uses.
    shift
    if [ "$#" -eq 0 ] || [ "${1#-}" != "$1" ]; then
      exec "$COOP_ROOT/scripts/uninstall.sh" "$@"
    fi
    have pi || coop_die "pi not installed."
    exec pi uninstall "$@"
    ;;
  list)          shift; have pi || coop_die "pi not installed."; exec pi list "$@" ;;
  config)        shift; have pi || coop_die "pi not installed."; exec pi config "$@" ;;
  pi)            shift; have pi || coop_die "pi not installed."; exec pi "$@" ;;
  version|--version|-V)
    printf 'coop %s\n' "$COOP_VERSION"
    if have pi; then printf 'pi   %s\n' "$(pi --version 2>/dev/null || echo '?')"; else printf 'pi   (not installed)\n'; fi
    ;;
  help|--help|-h) usage ;;
  -*)            launch_pi "$@" ;;   # unknown flags -> pass to pi (e.g. coop -c)
  *)             # Unknown subcommand: treat as pi input (files/messages).
                 launch_pi "$@" ;;
esac

coop_init_ci() {
  local dir="$1"
  local ci_type="$2"
  local py_cmd proj_yml="$dir/.coop/project.yml" defaults_yml="$COOP_ROOT/config/defaults.yml"
  
  if [ ! -f "$proj_yml" ]; then
    coop_die "$proj_yml not found. Run \`coop init\` first."
  fi
  
  if py_cmd="$(coop_python)"; then
    local out_file
    out_file="$("$py_cmd" "$COOP_ROOT/lib/_ciscaffold.py" "$ci_type" "$proj_yml" "$defaults_yml" "$dir")"
    local rc=$?
    if [ $rc -eq 0 ]; then
      coop_ok "Wrote $out_file"
    elif [ $rc -eq 3 ]; then
      coop_warn "No CI gates generated: paths missing in .coop/project.yml"
    else
      coop_err "CI scaffolding failed"
    fi
  else
    coop_die "Python 3 required to scaffold CI"
  fi
}
